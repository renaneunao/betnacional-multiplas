# Engine de Múltiplas do Brasileirão
# Usa Cartola como referência da rodada e Betnacional para odds

# URL da API do cliente Betnacional
BETNACIONAL_API_URL=http://betnacional-client:8001

# Número de jogos por múltipla (ex: 3 = triplas, 4 = quadruplas)
NUM_LEGS=3

# Valor por entrada em BRL
STAKE=1.00
